# ── Personal data: never committed ─────────────────────────────
# Working state (examples with .example suffix ARE committed)
state/*
!state/.gitkeep
!state/*.example.md
!state/*.example.json
!state/queue/
state/queue/*
!state/queue/.gitkeep

# Logs and backups
logs/*
!logs/.gitkeep
backups/

# Databases (schema lives in data/schema.sql, which IS committed)
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm

# Personal config (examples ARE committed)
config/aios.json
config/projects/*.json
!config/projects/*.json.example

# Vault: personal notes stay local; system templates/dashboards are committed
vault/00-inbox/*
vault/10-projects/*
vault/20-areas/*
vault/30-resources/*
vault/40-archive/*
!vault/**/.gitkeep
vault/90-system/dashboards/state-snapshot.md
.obsidian/
vault/.obsidian/

# Secrets
.env
.env.*

# ── OS / editor noise ───────────────────────────────────────────
.DS_Store
Thumbs.db
__pycache__/
*.pyc
